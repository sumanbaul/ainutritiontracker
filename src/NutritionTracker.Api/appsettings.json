{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "HealthChecks": {
    "EnableDatabaseReadinessCheck": true
  },
  "Authentication": {
    "Issuer": "NutriLens",
    "Audience": "NutriLens.Mobile",
    "SigningKey": "development-only-signing-key-change-me-000000",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "AllowRegistration": true
  },
  "Production": { "RequireHttps": true, "AllowedOrigins": [] },
  "MealVision": {
    "Provider": "Mock",
    "PromptVersion": "v1",
    "SchemaVersion": "1.0",
    "RequestTimeoutSeconds": 30,
    "MaximumImageBytes": 5000000,
    "MaximumItems": 20,
    "MinimumRecognitionConfidence": 0.75,
    "MinimumPortionConfidence": 0.65,
    "EnableClarificationQuestions": true,
    "EnableAlternativeCandidates": true,
    "EnableRawResponsePersistence": false,
    "AllowMockInProduction": false,
    "OpenAi": {
      "Endpoint": "https://api.openai.com/v1/",
      "Model": "gpt-5.4-mini",
      "ImageDetail": "low",
      "MaxOutputTokens": 2000
    },
    "Mock": {
      "Scenario": "BengaliLunch",
      "DelayMilliseconds": 0,
      "ForceMalformedResponse": false,
      "ForceTimeout": false,
      "ForceProviderFailure": false
    }
  },
  "MealAnalysis": {
    "Provider": "Local",
    "LocalStorageRoot": "App_Data/meal-images",
    "RetainImages": true,
    "RetentionDays": 30,
    "DeleteOnMealDelete": true,
    "AllowLocalInProduction": false,
    "MaximumImageBytes": 5000000,
    "AllowedMimeTypes": ["image/jpeg", "image/png", "image/webp"],
    "S3": { "Endpoint": "", "Region": "auto", "Bucket": "", "AccessKey": "", "SecretKey": "", "ForcePathStyle": true },
    "MaximumFileNameLength": 160
  },
  "NutritionCalculation": {
    "ActivityMultipliers": { "Sedentary": 1.20, "LightlyActive": 1.375, "ModeratelyActive": 1.55, "VeryActive": 1.725, "ExtraActive": 1.90 },
    "GoalCalorieAdjustments": { "MaintainWeight": 0, "LoseWeightSlowly": -250, "LoseWeightModerately": -500, "GainWeightSlowly": 250, "GainMuscle": 300, "Custom": 0 },
    "ProteinMultipliers": { "MaintainWeight": 1.4, "LoseWeightSlowly": 1.6, "LoseWeightModerately": 1.8, "GainWeightSlowly": 1.6, "GainMuscle": 1.8, "Custom": 0 },
    "MinimumCaloriesMale": 1500,
    "MinimumCaloriesFemale": 1200,
    "FatPercentage": 0.25,
    "MinimumFatGramsPerKg": 0.6,
    "FibreGramsPer1000Calories": 14,
    "MacroCalorieTolerance": 25,
    "MinimumSupportedAge": 18,
    "MaximumSupportedAge": 120
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
