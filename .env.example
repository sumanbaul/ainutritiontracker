# Copy this file to .env.local for local development. Do not commit .env.local.
# Secrets belong in .NET user secrets, never in this file.
POSTGRES_DB=nutrition_tracker
POSTGRES_USER=nutrition_tracker
POSTGRES_PASSWORD=replace-with-a-local-development-password
POSTGRES_PORT=5432

# NutriLens local development defaults (non-secret).
NUTRILENS_POSTGRES_DATABASE=nutrition_tracker_dev
NUTRILENS_API_HTTP_PORT=5241
NUTRILENS_DEVELOPMENT_USER_ID=local-mobile-user
NUTRILENS_ENABLE_MOCK_MODE=false
# Server-side provider selection is set with user secrets or environment variables.
# Supported IDs: OpenAi, Gemini, Anthropic, Ollama, OpenAiCompatible.
# Ollama is local to the development PC; default model: gemma3:4b.
# Never put API keys or remote endpoint credentials in this file or the Flutter app.
# NUTRILENS_API_BASE_URL=  # normally detected automatically for a physical Android device
# NUTRILENS_MOBILE_DEVICE=auto  # auto, emulator, or an adb device identifier
